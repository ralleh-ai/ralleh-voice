RALLEH_VOICE_ENV=dev
RALLEH_VOICE_HOST=127.0.0.1
RALLEH_VOICE_PORT=8099
RALLEH_VOICE_LOG_LEVEL=info
RALLEH_VOICE_WS_PATH=/v1/ws/voice
RALLEH_VOICE_STATIC_ENABLED=true
RALLEH_VOICE_OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
RALLEH_VOICE_OPENCLAW_TOKEN_REF=secret:openclaw_gateway_token
RALLEH_VOICE_OPENCLAW_GATEWAY_TIMEOUT_MS=10000
RALLEH_VOICE_KOKORO_VOICE=af_bella
RALLEH_VOICE_AUDIO_SAMPLE_RATE=16000

# Phase 1 adapter selection (deterministic defaults keep local tests lightweight)
RALLEH_VOICE_ADAPTER_VAD=deterministic
RALLEH_VOICE_ADAPTER_STT=deterministic
RALLEH_VOICE_ADAPTER_TTS=deterministic
RALLEH_VOICE_ADAPTER_BRIDGE=deterministic

# Optional model refs for real adapter wiring
RALLEH_VOICE_FASTER_WHISPER_MODEL_REF=model:faster-whisper-tiny
RALLEH_VOICE_FASTER_WHISPER_DEVICE=cpu
RALLEH_VOICE_FASTER_WHISPER_COMPUTE_TYPE=int8
RALLEH_VOICE_SILERO_MODEL_REF=model:silero-vad
RALLEH_VOICE_SILERO_SAMPLE_RATE=16000
RALLEH_VOICE_SILERO_THRESHOLD=0.5
RALLEH_VOICE_SILERO_MIN_SPEECH_MS=250
RALLEH_VOICE_SILERO_MIN_SILENCE_MS=150
RALLEH_VOICE_KOKORO_MODEL_REF=model:kokoro
RALLEH_VOICE_KOKORO_SAMPLE_RATE=24000
RALLEH_VOICE_KOKORO_OUTPUT_FORMAT=pcm_s16le
